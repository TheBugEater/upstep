# Database (Neon, Supabase, or any Postgres)
DATABASE_URL="postgresql://user:password@host:5432/upstep?sslmode=require"
DIRECT_URL="postgresql://user:password@host:5432/upstep?sslmode=require"

# NextAuth
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"
# Protects the notification retry endpoint. Use a long random value in production.
CRON_SECRET=""

# OAuth providers (optional)
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Email notifications (Resend — https://resend.com)
# Get your API key from resend.com/api-keys
RESEND_API_KEY=""
# Must be a verified sender in Resend (e.g. "Upstep <noreply@yourdomain.com>")
RESEND_FROM_EMAIL="Upstep <notifications@upstep.app>"

# Stripe billing
# Secret key from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=""
# Signing secret for the webhook endpoint (stripe listen / dashboard)
STRIPE_WEBHOOK_SECRET=""
# Recurring price IDs for each paid plan (Products → Pricing)
STRIPE_PRICE_PRO=""
STRIPE_PRICE_BUSINESS=""

# OnRamp analytics (https://getonramp.dev)
NEXT_PUBLIC_ONRAMP_API_KEY=""

# Upstep — dogfood: collect feedback on Upstep itself
# Create a project at /dashboard, copy its API key here.
# NEXT_PUBLIC_UPSTEP_BASE_URL should match AUTH_URL in production (e.g. https://upstep.dev)
NEXT_PUBLIC_UPSTEP_API_KEY=""
NEXT_PUBLIC_UPSTEP_BASE_URL="http://localhost:3000"
