{
  "name": "@upstep/js",
  "version": "0.5.12",
  "description": "Upstep feedback widget for web apps",
  "license": "MIT",
  "homepage": "https://upstep.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TheBugEater/upstep.git",
    "directory": "packages/sdk-web"
  },
  "bugs": "https://github.com/TheBugEater/upstep/issues",
  "keywords": ["feedback", "widget", "roadmap", "upstep", "react"],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build",
    "dev": "vite build --watch",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@upstep/types": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/react": "^19.0.7",
    "@vitejs/plugin-react": "^4.3.4",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-dts": "^4.4.0"
  }
}
